# ============================================================
# vLLM 高併發推論部署 - 環境設定範本
# ============================================================
# 將此檔案複製為 .env 並根據您的環境修改相應值
# 環境變數優先級：.env 檔案 > 程式碼預設值

# ============================================================
# 🗂️  一、模型與快取設定
# ============================================================

# HuggingFace 緩存目錄（存放下載的模型檔案）
HF_CACHE_DIR=./AImodels

# 是否信任遠端 HuggingFace 程式碼（某些模型需要執行自訂程式碼）
TRUST_REMOTE_CODE=true

# ============================================================
# 🖥️  二、共用伺服器設定
# ============================================================

# API 伺服器綁定的主機 IP（127.0.0.1 = 本地，0.0.0.0 = 所有網卡）
API_HOST=127.0.0.1

# API 金鑰（⚠️ 生產環境必須更改）
API_KEY=Rushia_Secret_Key_Change_Me

# ============================================================
# ⚙️  三、vLLM 引擎核心參數
# ============================================================

# 資料類型：auto（自動匹配 GPU）, float32, float16, bfloat16 等
DTYPE=auto

# 啟用前綴快取（加速重複請求，需更多顯存）
ENABLE_PREFIX_CACHING=true

# 禁用請求日誌（降低日誌開銷，大併發時建議開啟）
DISABLE_LOG_REQUESTS=false

# 禁用自訂 AllReduce（分散式訓練參數，通常保留預設）
DISABLE_CUSTOM_ALL_REDUCE=false

# 張量並行度（多 GPU 時提高此值以分散計算）
# 1 = 單 GPU，2 = 兩顆 GPU 以此類推
TENSOR_PARALLEL_SIZE=1

# 強制即時執行（禁用圖譜優化，CPU 記憶體充足時可降低顯存使用）
ENFORCE_EAGER=false

# 量化方法（留空 = 無量化，可選：awq, gptq, bitsandbytes 等）
QUANTIZATION=

# 自動工具選擇（函數調用模型參數）
ENABLE_AUTO_TOOL_CHOICE=true

# 工具調用解析器（優先使用 qwen3_coder）
TOOL_CALL_PARSER=qwen3_coder

# 允許的本地媒體路徑（/ = 不限制）
ALLOWED_LOCAL_MEDIA_PATH=/

# ============================================================
# 📸 四、多媒體參數
# ============================================================

# 影像最大尺寸（超過則自動縮放）
MAX_IMAGE_SIZE=2048

# 是否啟用影像自動縮放
ENABLE_IMAGE_RESIZE=true

# 影片萃取幀率（1.0 = 每秒 1 幀）
VIDEO_FPS=1.0

# 單次視頻分塊最大幀數
MAX_VIDEO_FRAMES_PER_CHUNK=64

# 影片幀的最大尺寸（縮放後）
MAX_VIDEO_FRAME_SIZE=768

# 影片幀 JPEG 品質（1-100）
VIDEO_FRAME_QUALITY=80

# ============================================================
# 💬 五、推論行為參數
# ============================================================

# 單個請求超時時間（秒）
REQUEST_TIMEOUT=300

# 預設生成 Token 數上限
DEFAULT_MAX_TOKENS=2048

# 預設溫度（0 = 確定性，1.0 = 平衡，> 1.0 = 更隨機）
DEFAULT_TEMPERATURE=0.8

# 文檔處理最大 Token 數
DOCUMENT_MAX_TOKENS=16384

# 視覺模型的溫度（獨立控制）
VISION_TEMPERATURE=1.0

# 核採樣參數（0.0-1.0，0.95 = 保留前 95% 概率的 Token）
DEFAULT_TOP_P=0.95

# Top-K 採樣（只考慮概率最高的 K 個 Token，0 = 禁用）
DEFAULT_TOP_K=20

# 最小概率（< MIN_P 的 Token 被過濾）
DEFAULT_MIN_P=0.0

# 存在懲罰（1.0 = 無懲罰，> 1.0 = 降低已出現詞頻）
DEFAULT_PRESENCE_PENALTY=1.5

# 重複懲罰（> 1.0 會懲罰重複 Token）
DEFAULT_REPETITION_PENALTY=1.1

# ============================================================
# 🔧 六、HuggingFace 與 CUDA 環境
# ============================================================

# 離線模式（0 = 連線，1 = 離線，需預先下載模型）
HF_HUB_OFFLINE=0

# 分詞器平行化（多進程時設為 false）
TOKENIZERS_PARALLELISM=false

# Triton PTXAS 編譯器路徑
TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas

# CUDA 安裝路徑
CUDA_HOME=/usr/local/cuda

# Triton 快取目錄
TRITON_CACHE_DIR=/tmp/triton_cache

# ============================================================
# 🌐 七、Gateway 多模型管理設定
# ============================================================

# Gateway 伺服器綁定的主機 IP
GATEWAY_HOST=0.0.0.0

# Gateway 伺服器監聽端口
GATEWAY_PORT=3000

# Gateway 請求超時時間（秒）
GATEWAY_REQUEST_TIMEOUT=300

# Gateway 最大並行請求數
GATEWAY_MAX_INFLIGHT=48

# 預設模型別名（如未指定則使用）
GATEWAY_DEFAULT_MODEL=

# ============================================================
# 🎯 八、模型配置說明
# ============================================================
# 多模型配置現在使用 models.json 檔案管理
# 請參考專案根目錄的 models.json 範例：
# 
# [
#   {
#     "alias": "qwen-9b",
#     "model_name": "./AImodels/Qwen3.5-9B",
#     "api_port": 8101,
#     "max_model_len": 32768,
#     "gpu_memory_utilization": 0.15,
#     "max_num_seqs": 48,
#     "max_num_batched_tokens": 65536
#   }
# ]
# 
# 可配置的欄位：
# - alias: 模型別名（必填，用於 API 選擇）
# - model_name: 模型路徑或 HuggingFace 模型 ID（必填）
# - api_port: 該模型獨佔的 API 端口（必填）
# - max_model_len: 模型的最大序列長度（選填，預設 4096）
# - gpu_memory_utilization: GPU 顯存使用率 0.0-1.0（選填，預設 0.95）
# - max_num_seqs: 最大並行序列數（選填，預設 64）
# - max_num_batched_tokens: 最大批次 Token 數（選填，預設 8192）
# - tiktoken_encodings_base: tiktoken 編碼目錄（選填，某些模型需要）
# - dtype: 資料類型（選填，預設 auto）
# - tensor_parallel_size: 張量並行大小（選填，預設 1）
# - quantization: 量化方法（選填，預設空）
# ============================================================
# 🌐 七、Gateway 多模型管理設定（可選）
# ============================================================

# Gateway 伺服器綁定的主機 IP
GATEWAY_HOST=0.0.0.0

# Gateway 伺服器監聽端口
GATEWAY_PORT=3000

# Gateway 請求超時時間（秒）
GATEWAY_REQUEST_TIMEOUT=300

# Gateway 最大並行請求數
GATEWAY_MAX_INFLIGHT=48

# 預設模型別名（如未指定則使用）
GATEWAY_DEFAULT_MODEL=

# Gateway 載入的模型設定檔清單（逗號分隔）
# 示例：.env.model.gpt-oss-20B,.env.model.Qwen3-14B-FP8
GATEWAY_MODEL_ENV_FILES=.env.model.gpt-oss-20B,.env.model.Qwen3-14B-FP8

# ============================================================
# 🎯 八、單一模型覆蓋設定（模型級別設定）
# ============================================================
# 複製以下內容到 .env.model.<MODEL_NAME> 檔案中
# 這些設定會覆蓋共用設定，用於特定模型的最佳化

# 模型別名（用於 API 選擇）
# MODEL_ALIAS=gemma-27b

# 模型路徑或 HuggingFace 模型 ID
# MODEL_NAME=./AImodels/gemma-3-27b-it

# 該模型獨佔的 API 端口
# API_PORT=8103

# 模型的最大序列長度（取決於模型架構）
# MAX_MODEL_LEN=24576

# GPU 顯存使用率（0.0-1.0，0.9 = 使用 90% 顯存）
# 顯存不足時降低此值
# GPU_MEMORY_UTILIZATION=0.9

# 最大並行序列數（per GPU）
# 降低此值可減少顯存，但會降低吞吐量
# MAX_NUM_SEQS=24

# 最大批次 Token 數（每次批處理的 Token 總數）
# MAX_NUM_BATCHED_TOKENS=49152

# ============================================================
# 💡 常見場景調優指南
# ============================================================
# 1️⃣ 顯存不足 (OOM)：
#    - 降低 GPU_MEMORY_UTILIZATION（如 0.7）
#    - 降低 MAX_NUM_SEQS
#    - 調整 MAX_NUM_BATCHED_TOKENS
#
# 2️⃣ 延遲過高：
#    - 增加 GPU_MEMORY_UTILIZATION（如 0.95）
#    - 增加 MAX_NUM_SEQS
#    - 設定 TENSOR_PARALLEL_SIZE > 1（多 GPU）
#
# 3️⃣ 吞吐量低：
#    - 啟用 ENABLE_PREFIX_CACHING=true
#    - 增加 MAX_NUM_BATCHED_TOKENS
#    - 啟用 ENFORCE_EAGER=true（若 CPU 記憶體充足）
#
# 4️⃣ 視覺模型效能差：
#    - 檢查 MAX_IMAGE_SIZE 是否合理
#    - 降低 VISION_TEMPERATURE 提高準確性
#    - 啟用 ENABLE_IMAGE_RESIZE=true
# ============================================================
