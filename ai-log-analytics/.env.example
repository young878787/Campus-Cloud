HOST=0.0.0.0
PORT=8011
API_V1_STR=/api/v1
FRONTEND_API_BASE_URL=

USE_DIRECT_PROXMOX=true
PROXMOX_HOST=your-proxmox-host
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your-password
PROXMOX_VERIFY_SSL=false
PROXMOX_API_TIMEOUT=30

USE_DIRECT_DATABASE=true
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
DATABASE_CONNECT_TIMEOUT=3

BACKEND_NODE_GPU_MAP={"pve":1,"pve2":1}
NODES_SNAPSHOT_JSON=[]
TOKEN_USAGE_SNAPSHOT_JSON=[]
GPU_METRICS_SNAPSHOT_JSON=[]

RECENT_WINDOW_MINUTES=60
BASELINE_DAYS=7
CASE_TOP_K=5
AGGREGATION_WINDOW_MINUTES=5
AGGREGATION_STAIR_COEFFICIENT=1.2

CPU_HIGH_THRESHOLD=0.85
MEMORY_HIGH_THRESHOLD=0.85
DISK_HIGH_THRESHOLD=0.9
TOKEN_SPIKE_RATIO=1.5

VLLM_BASE_URL=http://localhost:8000
VLLM_API_KEY=vllm-secret-key-change-me
VLLM_MODEL_NAME=
VLLM_TIMEOUT=10
