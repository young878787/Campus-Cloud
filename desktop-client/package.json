{
  "name": "campus-cloud-connect",
  "version": "0.1.0",
  "main": "dist-electron/main/index.js",
  "description": "Campus Cloud Connect desktop client",
  "private": true,
  "engines": {
    "node": ">= 22.12.0"
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:electron": "npm run build && electron-builder -p never",
    "build:electron:win": "npm run build && electron-builder --win -p never",
    "build:electron:mac": "npm run build && electron-builder --mac -p never",
    "build:electron:linux": "npm run build && electron-builder --linux -p never",
    "preview": "vite preview",
    "lint": "eslint src/ electron/ --ext .ts,.tsx,.vue",
    "lint:fix": "eslint src/ electron/ --ext .ts,.tsx,.vue --fix"
  },
  "devDependencies": {
    "@iconify-icons/material-symbols": "^1.2.58",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/nedb": "^1.8.16",
    "@types/node": "^24.9.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^7.1.0",
    "autoprefixer": "^10.4.21",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "postcss": "^8.4.31",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "sass": "^1.93.3",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.3.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.1.2"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "@electron/asar": {
      "minimatch": "^3.1.2"
    },
    "underscore": ">=1.13.8"
  },
  "dependencies": {
    "@vueuse/core": "^14.0.0",
    "animate.css": "^4.1.1",
    "electron-log": "^5.4.3",
    "element-plus": "^2.11.7",
    "nedb": "^1.8.0",
    "pinia": "^3.0.3",
    "tree-kill": "^1.2.2",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.2",
    "vue-router": "^4.6.3"
  }
}
