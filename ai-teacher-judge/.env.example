# Server Configuration
HOST=127.0.0.1
PORT=8010
FRONTEND_API_BASE_URL=

# Security Settings
MAX_UPLOAD_SIZE_MB=10
CORS_ORIGINS=

# vLLM AI Service Configuration
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm-secret-key-change-me
VLLM_MODEL_NAME=
VLLM_ENABLE_THINKING=false
VLLM_TIMEOUT=60

# Sampling Parameters
# Temperature: 越高越有創造性，越低越穩定（0 代表接近貪婪解碼）
VLLM_TEMPERATURE=0.2
VLLM_CHAT_TEMPERATURE=0.7
# 核心取樣（Nucleus Sampling）：限制在累積機率 top_p 內抽樣
VLLM_TOP_P=0.95
# 每步僅保留機率最高的前 K 個候選 token（0 代表不啟用 top_k 限制）
VLLM_TOP_K=20
# 最小機率門檻：低於此機率的 token 不會被抽樣
VLLM_MIN_P=0.0
# 重複懲罰：大於 1.0 可降低重複 token；1.0 代表不懲罰
VLLM_REPETITION_PENALTY=1.0
# Maximum tokens for analysis and chat
VLLM_MAX_TOKENS=8192
VLLM_CHAT_MAX_TOKENS=4096

