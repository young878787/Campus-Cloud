HOST=127.0.0.1
PORT=8010
FRONTEND_API_BASE_URL=
BACKEND_AUTH_EMAIL=
BACKEND_AUTH_PASSWORD=
PROXMOX_HOST=
PROXMOX_USER=
PROXMOX_PASSWORD=
PROXMOX_NODE=pve
PROXMOX_ISO_STORAGE=local
PROXMOX_VERIFY_SSL=false
PROXMOX_API_TIMEOUT=15

# Path to the existing template catalog
TEMPLATES_DIR=../frontend/src/json

# Internal nodes API
USE_INTERNAL_NODES_API=true

# Internal node snapshot used by /api/v1/resources/nodes
NODES_SNAPSHOT_JSON=[{"node":"pve","status":"online","cpu":0.35,"maxcpu":16,"mem":30923764531,"maxmem":68719476736,"uptime":86400}]

# Optional static GPU counts because the node snapshot does not currently expose GPU info.
# Example: {"pve-1": 1, "pve-2": 0}
BACKEND_NODE_GPU_MAP={"pve": 1}

# AI planner
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm-secret-key-change-me
VLLM_MODEL_NAME=
VLLM_ENABLE_THINKING=false
VLLM_TIMEOUT=30

# 取樣溫度：越高越有創造性，越低越穩定（0 代表接近貪婪解碼）
VLLM_TEMPERATURE=0.6
# 核心取樣（Nucleus Sampling）：限制在累積機率 top_p 內抽樣
VLLM_TOP_P=0.95
# 每步僅保留機率最高的前 K 個候選 token（0 代表不啟用 top_k 限制）
VLLM_TOP_K=20
# 最小機率門檻：低於此機率的 token 不會被抽樣
VLLM_MIN_P=0.0
# 存在懲罰：提高後可降低重複提及已出現主題的機率
VLLM_PRESENCE_PENALTY=0.0
# 重複懲罰：大於 1.0 可降低重複 token；1.0 代表不懲罰
VLLM_REPETITION_PENALTY=1.0
