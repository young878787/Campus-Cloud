# ============================================================
# .env 範本 - 複製為 .env 後依需求修改
# 優先級: .env > config/settings.py 預設值
# ============================================================

# ---- 模型設定 ----
# 可用模型 (已快取在 /raid/hf-cache/hub):
#   /raid/hf-cache/hub/Gemma-4-26B-A4B-it-NVFP4  (MoE 視覺-語言, NVFP4 量化)
#   nvidia/Qwen3-235B-A22B-NVFP4                  (純文字, NVFP4 量化)
#   Qwen/Qwen3-VL-30B-A3B-Thinking-FP8            (視覺-語言, FP8 量化)
#   hugging-quants/Meta-Llama-3.1-405B-Instruct-AWQ-INT4
MODEL_NAME=nvidia/Qwen3-235B-A22B-NVFP4
HF_CACHE_DIR=/raid/hf-cache/hub
TRUST_REMOTE_CODE=true

# ---- 伺服器設定 ----
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=vllm-secret-key-change-me

# ---- vLLM 引擎參數 ----
DTYPE=auto
# 模型上下文長度上限（token）
# 純文字: 4096–8192；視覺/長文: 32768–131072；Gemma4 最高支援 262144
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.95
MAX_NUM_SEQS=64
MAX_NUM_BATCHED_TOKENS=8192
TENSOR_PARALLEL_SIZE=1
ENFORCE_EAGER=false
ENABLE_PREFIX_CACHING=true
DISABLE_LOG_REQUESTS=false
DISABLE_CUSTOM_ALL_REDUCE=false
# 量化方法: awq | gptq | fp8 | modelopt（NVFP4 用）；留空則不傳入
QUANTIZATION=
# KV Cache 類型: fp8 | auto；留空則由 vLLM 自動選擇
KV_CACHE_DTYPE=
# 非 MoE 層 NVFP4 GEMM backend（SM 12.x Blackwell 用）: marlin；留空則由 vLLM 自動選擇
VLLM_NVFP4_GEMM_BACKEND=

# ---- Tool Calling / Function Calling ----
ENABLE_AUTO_TOOL_CHOICE=false
# 工具呼叫解析器: openai | mistral | hermes | gemma4 | internlm | qwen3_xml | qwen3_coder；留空則不傳入
TOOL_CALL_PARSER=
# 推理解析器: gemma4；留空則不傳入 --reasoning-parser
REASONING_PARSER=
# Chat template 路徑（Jinja2 格式）；啟用 tool-call-parser 或 reasoning-parser 時通常必填
# 範例: config/tool_chat_template_gemma4.jinja
# 留空則不傳入，由 vLLM 使用模型內建 template
CHAT_TEMPLATE=
# MoE expert 層 backend: marlin；留空則由 vLLM 自動選擇
# modelopt NVFP4 量化的 MoE 模型（如 Gemma 4 NVFP4）需設 marlin，否則輸出會退化
MOE_BACKEND=

# ---- 視覺模型設定 (Vision-Language Models) ----
MODEL_TYPE=auto
MAX_IMAGE_SIZE=1024
ENABLE_IMAGE_RESIZE=true
# 允許 vLLM 讀取本機媒體檔案的根目錄；'/' 表示任意路徑
ALLOWED_LOCAL_MEDIA_PATH=/
# 每個 prompt 允許的多模態輸入上限（JSON 格式）；留空則不傳入，由 vLLM 使用模型預設值
# 範例: {"image": 5, "video": 1, "audio": 0}
LIMIT_MM_PER_PROMPT=

# ---- 影片模型設定 (Video Input) ----
# 抽幀速率（幀/秒）；降低可節省 token
VIDEO_FPS=1.0
# 每段最大幀數上限；超過則自動切分多段推論後彙整
MAX_VIDEO_FRAMES_PER_CHUNK=64
# 影片幀縮放尺寸（長邊 px）
MAX_VIDEO_FRAME_SIZE=768
# 影片幀 JPEG 壓縮品質 (1-100)
VIDEO_FRAME_QUALITY=80

# ---- 併發與效能 ----
UVICORN_WORKERS=1
REQUEST_TIMEOUT=300

# ---- Webapp 推論參數 ----
DEFAULT_MAX_TOKENS=2048
DEFAULT_TEMPERATURE=0.7
DOCUMENT_MAX_TOKENS=4096
VISION_TEMPERATURE=0.75
DEFAULT_TOP_P=0.95
DEFAULT_TOP_K=20
DEFAULT_MIN_P=0.0
DEFAULT_PRESENCE_PENALTY=1.5
DEFAULT_REPETITION_PENALTY=1.0

# ---- Benchmark 設定 ----
BENCH_TOTAL_REQUESTS=50
BENCH_CONCURRENCY=10
BENCH_MAX_TOKENS=256
BENCH_PROMPT=請用繁體中文簡要介紹什麼是人工智慧？

# ---- HuggingFace 設定 ----
HF_HUB_OFFLINE=1
VLLM_USAGE_STATS_ENABLED=0
TOKENIZERS_PARALLELISM=false

# ---- Triton/CUDA 設定 (Blackwell 等新 GPU 必需) ----
TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas
CUDA_HOME=/usr/local/cuda
TRITON_CACHE_DIR=/tmp/triton_cache
