# ============================================================
# .env 範本 - 複製為 .env 後修改
# ============================================================

# ---- 模型設定 ----
# 可用模型 (已快取在 /raid/hf-cache/hub):
#   nvidia/Qwen3-235B-A22B-NVFP4          (純文字模型)
#   Qwen/Qwen3-Next-80B-A3B-Thinking-FP8  (純文字模型)
#   Qwen3-VL-30B-A3B-Thinking-FP8         (視覺-語言模型 ✨)
#   hugging-quants/Meta-Llama-3.1-405B-Instruct-AWQ-INT4
#   openai/gpt-oss-120b
MODEL_NAME=nvidia/Qwen3-235B-A22B-NVFP4
HF_CACHE_DIR=/raid/hf-cache/hub
TRUST_REMOTE_CODE=true

# ---- 伺服器設定 ----
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=vllm-secret-key-change-me

# ---- vLLM 引擎參數 ----
DTYPE=auto
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.95
MAX_NUM_SEQS=64                      # 最大併發序列數
MAX_NUM_BATCHED_TOKENS=8192          # 單批次最大 token 數
TENSOR_PARALLEL_SIZE=1               # 張量並行數 (多 GPU)
ENFORCE_EAGER=false                  # 強制 eager 模式 (調試用)
ENABLE_PREFIX_CACHING=true           # 啟用前綴快取 (提升效能)
DISABLE_LOG_REQUESTS=false           # 停用請求日誌
DISABLE_CUSTOM_ALL_REDUCE=false      # 停用自定義 all-reduce (穩定性)
QUANTIZATION=                        # 量化方法 (awq, gptq, fp8)
# ---- Tool Calling / Function Calling ----
ENABLE_AUTO_TOOL_CHOICE=false        # 啟用自動工具呼叫 (true/false)
TOOL_CALL_PARSER=hermes              # 解析器: openai | mistral | hermes | llama3_json | internlm

# ---- 視覺模型設定 (Vision-Language Models) ----
# 模型類型: auto (自動檢測), text (純文字), vision (視覺模型)
MODEL_TYPE=auto
# 最大圖片尺寸（調整後的長邊，單位: px）
MAX_IMAGE_SIZE=1024
# 是否自動調整圖片大小以節省記憶體
ENABLE_IMAGE_RESIZE=true

# ---- 併發與效能 ----
UVICORN_WORKERS=1
REQUEST_TIMEOUT=300

# ---- Benchmark 設定 ----
BENCH_TOTAL_REQUESTS=50
BENCH_CONCURRENCY=10
BENCH_MAX_TOKENS=256
BENCH_PROMPT=請用繁體中文簡要介紹什麼是人工智慧？

# ---- Webapp 推論參數 (統一管理，避免硬編碼) ----
DEFAULT_MAX_TOKENS=2048              # 預設最大生成 token 數
DEFAULT_TEMPERATURE=0.7              # 預設溫度參數 (0.0-2.0)
DOCUMENT_MAX_TOKENS=4096             # 文件模式最大 token 數 (需要更長輸出)
VISION_TEMPERATURE=0.75              # 視覺模式溫度 (稍高以增加創造性)

# ---- HuggingFace 設定 ----
HF_HUB_OFFLINE=1
VLLM_USAGE_STATS_ENABLED=0
TOKENIZERS_PARALLELISM=false

# ---- Triton/CUDA 設定 (關鍵！Blackwell 等新 GPU 必需) ----
TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas
CUDA_HOME=/usr/local/cuda
TRITON_CACHE_DIR=/tmp/triton_cache

